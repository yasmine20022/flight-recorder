# Copy this file to ".env" and fill in your free Groq key from https://console.groq.com
GROQ_API_KEY=gsk_your_free_key_here

# LLM model (free on Groq). 8b-instant has a generous free daily token budget.
GROQ_MODEL=llama-3.1-8b-instant

# Path to the SQLite trace database (relative to backend/)
DATABASE_PATH=flight_recorder.db
