# Copy this file to ".env" and fill in your free Groq key from https://console.groq.com
GROQ_API_KEY=gsk_your_free_key_here

# LLM model (free on Groq). 8b-instant has a generous free daily token budget.
GROQ_MODEL=llama-3.1-8b-instant

# Path to the SQLite trace database (relative to backend/)
DATABASE_PATH=flight_recorder.db

# --- Optional: connect to a REAL Jira instead of the local mock ---
# Leave blank to use the bundled mock data (works fully offline).
# 1. Create a free Atlassian site: https://www.atlassian.com/software/jira/free
# 2. Create an API token:          https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
